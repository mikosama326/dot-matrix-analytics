<% content_for :title, "Dot Matrix Telemetry Dashboard" %>
<style>
  :root {
    --bg: #0b1020;
    --panel: #111827;
    --panel-2: #1f2937;
    --border: #334155;
    --text: #f8fafc;
    --muted: #94a3b8;
    --accent: #38bdf8;
    --accent-2: #a78bfa;
    --good: #34d399;
  }

  body {
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(56, 189, 248, 0.16), transparent 32rem),
      radial-gradient(circle at top right, rgba(167, 139, 250, 0.13), transparent 30rem),
      var(--bg);
    color: var(--text);
  }

  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
    margin-bottom: 28px;
  }

  h1 {
    font-size: 44px;
    margin: 0 0 8px;
    letter-spacing: -0.04em;
  }

  h2 {
    margin-top: 42px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }

  .subtitle, .muted {
    color: var(--muted);
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(52, 211, 153, 0.4);
    background: rgba(52, 211, 153, 0.1);
    color: var(--good);
    padding: 8px 12px;
    border-radius: 999px;
    font-weight: 700;
  }

  .live-dot {
    width: 9px;
    height: 9px;
    background: var(--good);
    border-radius: 999px;
    box-shadow: 0 0 16px var(--good);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 16px;
  }

  .card, .panel {
    background: linear-gradient(180deg, rgba(31, 41, 55, 0.92), rgba(17, 24, 39, 0.92));
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  }

  .card {
    padding: 22px;
  }

  .card-label {
    color: var(--muted);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-value {
    font-size: 38px;
    font-weight: 800;
    margin-top: 10px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .panel {
    padding: 18px;
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(51, 65, 85, 0.7);
    vertical-align: top;
  }

  th {
    text-align: left;
    color: #cbd5e1;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  tr:last-child td {
    border-bottom: none;
  }

  pre {
    margin: 0;
    white-space: pre-wrap;
    color: #dbeafe;
    font-size: 12px;
  }

  .pill {
    display: inline-block;
    padding: 5px 9px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.14);
    border: 1px solid rgba(56, 189, 248, 0.35);
    color: #bae6fd;
    font-size: 12px;
    font-weight: 700;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .flash {
    animation: flash 0.6s ease-out;
  }

  @keyframes flash {
    from {
      color: var(--good);
      text-shadow: 0 0 18px var(--good);
    }
    to {
      color: var(--text);
      text-shadow: none;
    }
  }
</style>

<main>
  <section class="header">
    <div>
      <h1>Dot Matrix Telemetry Dashboard</h1>
      <div class="subtitle">Live analytics from production gameplay sessions.</div>
    </div>

    <div class="live-badge">
      <span class="live-dot"></span>
      LIVE
    </div>
  </section>

  <section class="cards">
    <div class="card">
      <div class="card-label">Sessions</div>
      <div class="card-value" data-stat="total-sessions"><%= @total_sessions %></div>
    </div>

    <div class="card">
      <div class="card-label">Unique Players</div>
      <div class="card-value" data-stat="unique-players"><%= @unique_players %></div>
    </div>

    <div class="card">
      <div class="card-label">Total Active Minutes</div>
      <div class="card-value" data-stat="active-minutes"><%= (@total_active_seconds / 60.0).round(2) %></div>
    </div>
  </section>

  <section class="grid">
    <div>
      <h2>Most Popular Items</h2>
      <div class="panel table-wrap">
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Placements</th>
            </tr>
          </thead>
          <tbody id="items-placed-body">
            <% @item_placed_counts.each do |item_name, count| %>
              <tr>
                <td><%= item_name || "(unknown)" %></td>
                <td><%= count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

<h2>Current Sessions</h2>
<div class="panel table-wrap">
  <table>
    <thead>
      <tr>
        <th>Last Seen</th>
        <th>Active</th>
        <th>Dots</th>
        <th>Production</th>
        <th>Consumption</th>
        <th>Last Event</th>
        <th>Last Item</th>
        <th>Item Level</th>
      </tr>
    </thead>
    <tbody id="recent-sessions-body">
      <% @recent_sessions.each do |session| %>
        <tr>
          <td class="muted" data-timestamp="<%= session.last_seen_at&.iso8601 %>"></td>
          <td><%= session.active_seconds.to_i < 60 ? "#{session.active_seconds.to_i} sec" : "#{(session.active_seconds.to_i / 60.0).round(1)} min" %></td>
          <td><%= session.last_dots_available || "—" %></td>
          <td><%= session.last_dot_production_rate.nil? ? "—" : "+#{session.last_dot_production_rate.round(2)}/s" %></td>
          <td><%= session.last_dot_consumption_rate.nil? ? "—" : "-#{session.last_dot_consumption_rate.round(2)}/s" %></td>
          <td><span class="pill"><%= session.last_event_name || "—" %></span></td>
          <td><%= session.last_item_id || "—" %></td>
          <td><%= session.last_item_level || "—" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

  <h2>Live Event Feed</h2>
  <div class="panel table-wrap">
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Event</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="recent-events-body">
        <% @recent_events.each do |event| %>
          <tr>
            <td class="muted" data-timestamp="<%= event.created_at.iso8601 %>"></td>
            <td><span class="pill"><%= event.event_name %></span></td>
            <td><pre><%= JSON.pretty_generate(event.properties || {}) %></pre></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <script type="module">
    import { createConsumer } from "@rails/actioncable";

    const consumer = createConsumer();

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatTime(value) {
      if (!value) return "Unknown";
  
      return new Date(value).toLocaleString([], {
          year: "numeric",
          month: "short",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit"
      });
    }

    function formatActiveTime(seconds) {
      const value = Number(seconds || 0);

      if (value < 60) {
        return `${value} sec`;
      }

      return `${(value / 60.0).toFixed(1)} min`;
    }

    function updateStat(name, value) {
      const el = document.querySelector(`[data-stat='${name}']`);
      if (!el) return;

      el.textContent = value;
      el.classList.remove("flash");
      void el.offsetWidth;
      el.classList.add("flash");
    }

    function renderEventCounts(eventCounts) {
      const body = document.querySelector("#event-counts-body");
      if (!body) return;

      body.innerHTML = Object.entries(eventCounts).map(([eventName, count]) => `
        <tr>
          <td><span class="pill">${escapeHtml(eventName)}</span></td>
          <td>${escapeHtml(count)}</td>
        </tr>
      `).join("");
    }

    function renderItemsPlaced(itemCounts) {
      const body = document.querySelector("#items-placed-body");
      if (!body) return;

      body.innerHTML = Object.entries(itemCounts).map(([itemName, count]) => `
        <tr>
          <td>${escapeHtml(itemName || "(unknown)")}</td>
          <td>${escapeHtml(count)}</td>
        </tr>
      `).join("");
    }

    function renderRecentEvents(events) {
      const body = document.querySelector("#recent-events-body");
      if (!body) return;

      body.innerHTML = events.map((event) => `
        <tr>
          <td class="muted">${escapeHtml(formatTime(event.created_at))}</td>
          <td><span class="pill">${escapeHtml(event.event_name)}</span></td>
          <td><pre>${escapeHtml(JSON.stringify(event.properties || {}, null, 2))}</pre></td>
        </tr>
      `).join("");
    }

function formatNumber(value, digits = 2) {
  if (value === null || value === undefined || value === "") return "—";
  return Number(value).toFixed(digits);
}

function renderRecentSessions(sessions) {
  const body = document.querySelector("#recent-sessions-body");
  if (!body) return;

  body.innerHTML = sessions.map((session) => `
    <tr>
      <td class="muted">${escapeHtml(formatTime(session.last_seen_at))}</td>
      <td>${escapeHtml(formatActiveTime(session.active_seconds))}</td>
      <td>${escapeHtml(session.last_dots_available ?? "—")}</td>
      <td>${escapeHtml(session.last_dot_production_rate == null ? "—" : `+${formatNumber(session.last_dot_production_rate)}/s`)}</td>
      <td>${escapeHtml(session.last_dot_consumption_rate == null ? "—" : `-${formatNumber(session.last_dot_consumption_rate)}/s`)}</td>
      <td><span class="pill">${escapeHtml(session.last_event_name || "—")}</span></td>
      <td>${escapeHtml(session.last_item_id || "—")}</td>
      <td>${escapeHtml(session.last_item_level ?? "—")}</td>
    </tr>
  `).join("");
}

    consumer.subscriptions.create("DashboardChannel", {
      connected() {
        console.log("Connected to DashboardChannel");
      },

      received(data) {
        console.log("Live dashboard update received", data);

        if ("total_sessions" in data) updateStat("total-sessions", data.total_sessions);
        if ("unique_players" in data) updateStat("unique-players", data.unique_players);

        if ("total_active_seconds" in data) {
          updateStat("active-minutes", (data.total_active_seconds / 60.0).toFixed(2));
        }

        if ("event_counts" in data) {
          renderEventCounts(data.event_counts);
        }

        if ("item_placed_counts" in data) {
          renderItemsPlaced(data.item_placed_counts);
        }

        if ("recent_events" in data) {
          renderRecentEvents(data.recent_events);
        }

        if ("recent_sessions" in data) {
          renderRecentSessions(data.recent_sessions);
        }
      }
    });

    document.querySelectorAll("[data-timestamp]").forEach((element) => {
  element.textContent = formatTime(element.dataset.timestamp);
});
  </script>
</main>